# OpenFund-AI environment variables
# Copy to .env and set real values:  cp .env.example .env
# The app loads .env automatically when load_config() runs (python-dotenv).

# --- Demo mode (static data, no external APIs) ---
# OPENFUND_DEMO=1
# DEMO=1

# --- Persistence ---
MEMORY_STORE_PATH=memory
E2E_TIMEOUT_SECONDS=30

# --- PostgreSQL (sql_tool) ---
# Use a role that exists. On macOS Homebrew Postgres the default superuser is your
# OS username (e.g. jiani). Examples:
#   DATABASE_URL=postgresql://jiani@localhost:5432/openfund
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/openfund
# Create DB first: createdb openfund   (or: psql -c "CREATE DATABASE openfund;")
# DATABASE_URL=postgresql://YOUR_OS_USER@localhost:5432/openfund

# --- Neo4j (kg_tool) ---
# NEO4J_USER and NEO4J_PASSWORD must match the Neo4j server. Default user is "neo4j";
# set the password in Neo4j (e.g. first-time browser prompt, or neo4j-admin set-initial-password).
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_password
# NEO4J_DATABASE=neo4j

# --- Milvus (vector_tool) ---
# Start Milvus first: ./scripts/start_milvus.sh  (plain docker run does not start the server)
# Wait ~30s for the server to be ready, then run python -m data populate.
# MILVUS_URI=http://localhost:19530
# MILVUS_COLLECTION=openfund_docs
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DIM=384

# --- Market / web (market_tool) ---
# TAVILY_API_KEY=your_tavily_key
# YAHOO_BASE_URL=
# ALPHA_VANTAGE_API_KEY=your_av_key
# MCP_MARKET_VENDOR=yfinance
# MCP_INDICATOR_VENDOR=yfinance
# MCP_DATA_CACHE_DIR=

# --- Analyst API ---
# ANALYST_API_URL=http://localhost:5001
# ANALYST_API_KEY=

# --- LLM (task decomposition, optional) ---
# LLM_API_KEY=your_openai_key
# LLM_MODEL=gpt-4o-mini

# --- MCP server (if using remote MCP) ---
# MCP_SERVER_ENDPOINT=

# --- File tool path safety ---
# MCP_FILE_BASE_DIR=/path/to/allowed/files

# --- Thresholds (optional) ---
# PLANNER_SUFFICIENCY_THRESHOLD=0.6
# ANALYST_CONFIDENCE_THRESHOLD=0.6
# RESPONDER_CONFIDENCE_THRESHOLD=0.75
